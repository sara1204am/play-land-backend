generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex", "views"]
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model access_token {
  id        String    @id @default(uuid())
  expiresAt DateTime  @map("expires_at") @db.DateTime(0)
  userId    String?   @db.VarChar(50)
  token     String    @unique @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.DateTime(0)
}

model user {
  id                  String    @id @default(uuid()) @db.VarChar(50)
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime? @map("updated_at") @db.DateTime(0)
  firstName           String?   @map("first_name") @db.VarChar(100)
  lastName            String?   @map("last_name") @db.VarChar(100)
  username            String?   @db.VarChar(100)
  password            String?   @db.VarChar(100)
  email               String?   @unique(map: "email") @db.VarChar(100)
  emailVerified       Boolean?  @map("email_verified")
  verificationToken   String?   @map("verification_token") @db.VarChar(100)
  status              Boolean?  @db.TinyInt()

  @@map("user")
}


model user_login_log {
  id          String    @id @db.VarChar(50) @default(uuid())
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  loggedOutAt DateTime? @map("logged_out_at") @db.Timestamp(6)
  userId      String    @map("user_id") @db.VarChar(50)
  ip          String?   @db.VarChar(50)
  token       String?   @db.VarChar(255)
  hostInfo    String?   @map("host_info") @db.VarChar(255)
  platform    String?   @db.VarChar(100)

}


model user_token_config {
  id                       String    @id @db.VarChar(50)
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  userId                   String?   @map("user_id") @db.VarChar(50)
  matrix                   String?
  type                     Int?      @db.SmallInt
  key                      String?   @db.VarChar(100)
  external_two_factor_auth String?
}


model lote {
  id                String      @id 
  fecha             DateTime?   
  nombre            String?     
  costo             Int?        
  total_pagado      String?     
  adelantos         String?     
  costo_transporte  String?     
  medio_transporte  String?     
  proveedor_nombre  String?     
  proveedor_celular String?     
  proveedor_ciudad  String?    

  @@map("lotes")
}


model articulo {
  id                  String     @id @default(uuid()) 
  nombre              String?    
  nombre_corto        String?    
  descripcion         String?    
  cantidad            Int?      
  costo_unitario      Int?      
  precio              Int?       
  precio_maximo       Int?       
  active              Boolean?     
  stock_by_option     Json?
  chips     Json?
  type                String?
  descuento           Int?  
  id_lote             String?   
  created_at          DateTime? @default(now()) @db.Timestamp(6)  
  imagenes            imagenes[]
  stock_fisico            stock_fisico[]
  conteos_fisicos_detalle conteo_fisico_detalle[]

  @@map("articulos")
}


model venta {
  id          String      @id @default(uuid()) 
  fecha       DateTime? 
  total       Float?      
  nota        String?   
  detail      Json?
  detail_generico  Json?

  @@map("ventas")
}

model imagenes {
  id          String    @id @default(uuid()) 
  nombre      String?   
  id_articulo String?
  url         String?
  url_2       String?
  articulo    articulo? @relation(fields: [id_articulo], references: [id])

}



model ubicacion {
  id          String    @id @default(uuid())
  nombre      String    @db.VarChar(100)
  descripcion String?   @db.VarChar(255)
  activo      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @map("updated_at") @db.DateTime(0)

  stock_fisico            stock_fisico[]
  conteos_fisicos_detalle conteo_fisico_detalle[]

  @@map("ubicaciones")
}

model stock_fisico {
  id          String    @id @default(uuid())
  articuloId  String    @map("articulo_id")
  variante    String?   @db.VarChar(150)
  ubicacionId String    @map("ubicacion_id")
  cantidad    Int       @default(0)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @map("updated_at") @db.DateTime(0)
  createdById String?   @map("created_by")
  updatedById String?   @map("updated_by")

  articulo  articulo  @relation(fields: [articuloId], references: [id])
  ubicacion ubicacion @relation(fields: [ubicacionId], references: [id])

  @@unique([articuloId, variante, ubicacionId], name: "articulo_variante_ubicacion")
  @@map("stock_fisico")
}

model conteo_fisico {
  id          String    @id @default(uuid())
  nombre      String?   @db.VarChar(150)
  fecha       DateTime? @default(now())
  observacion String?   @db.VarChar(255)
  createdById String?   @map("created_by")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  detalles conteo_fisico_detalle[]

  @@map("conteos_fisicos")
}

model conteo_fisico_detalle {
  id              String    @id @default(uuid())
  conteoId        String    @map("conteo_id")
  articuloId      String    @map("articulo_id")
  variante        String?   @db.VarChar(150)
  ubicacionId     String    @map("ubicacion_id")
  cantidadSistema Int?      @default(0) @map("cantidad_sistema")
  cantidadContada Int?      @default(0) @map("cantidad_contada")
  diferencia      Int?      @default(0)
  contadoById     String?   @map("contado_by")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  conteo    conteo_fisico @relation(fields: [conteoId], references: [id])
  articulo  articulo      @relation(fields: [articuloId], references: [id])
  ubicacion ubicacion     @relation(fields: [ubicacionId], references: [id])

  @@map("conteos_fisicos_detalle")
}
